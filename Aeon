#!/bin/bash
set -e
set -o pipefail

# ── Configuration ──
readonly SCRIPT_NAME="$(basename "$0")"
readonly LOG_FILE="/var/log/setup_$(date +%Y%m%d_%H%M%S).log"
readonly MEGA_VENV="/opt/mega-venv"
readonly SDK_PATH="/home/sdk"
readonly TEMP_DIR="/tmp/build_temp"

# ── Logging ──
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

error_exit() {
    log "❌ ERROR: $*"
    exit 1
}

# ── Root Check ──
check_root() {
    if [ "$EUID" -ne 0 ]; then
        error_exit "This script must be run as root (use sudo)"
    fi
}

# ── Update system ──
update_system() {
    log "🔄 Updating system packages..."
    apt-get update -qq && apt-get upgrade -y -qq
    log "✅ System updated"
}

# ── Python 3.12 ──
install_python() {
    log "🐍 Installing Python 3.12..."
    apt-get install -y -qq software-properties-common
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update -qq
    apt-get install -y -qq \
        python3.12 python3.12-dev python3.12-venv \
        python3-pip libpython3.12-dev \
        dh-autoreconf
    log "✅ Python 3.12 installed"
}

# ── System dependencies ──
install_dependencies() {
    log "📦 Installing system dependencies..."
    apt-get install -y --no-install-recommends -qq \
        apt-utils aria2 curl zstd git libmagic-dev \
        locales mediainfo neofetch p7zip-full \
        p7zip-rar tzdata wget autoconf automake \
        build-essential cmake g++ gcc gettext \
        gpg-agent intltool libtool make unzip zip \
        libcurl4-openssl-dev libsodium-dev libssl-dev \
        libcrypto++-dev libc-ares-dev libsqlite3-dev \
        libfreeimage-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev \
        pkg-config libffi-dev libpcre3-dev \
        libuv1-dev libmediainfo0v5 ca-certificates \
        libarchive-tools
    log "✅ Dependencies installed"
}

# ── qbittorrent-nox static → xnox ──
install_qbittorrent() {
    log "🧲 Installing qbittorrent-nox (xnox)..."
    local ARCH=$(uname -m)
    local QB_URL=""
    
    case "$ARCH" in
        x86_64)
            QB_URL="https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/x86_64-qbittorrent-nox"
            ;;
        aarch64)
            QB_URL="https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/aarch64-qbittorrent-nox"
            ;;
        *)
            error_exit "Unsupported architecture: $ARCH"
            ;;
    esac
    
    mkdir -p /usr/local/bin
    wget -q --show-progress -O /usr/bin/xnox "$QB_URL" || error_exit "Failed to download qbittorrent"
    chmod 755 /usr/bin/xnox
    log "✅ qbittorrent-nox installed as 'xnox'"
}

# ── Custom FFmpeg → xtra ──
install_ffmpeg() {
    log "🎬 Installing custom FFmpeg (xtra)..."
    local ARCH=$(uname -m)
    local FF_URL=""
    
    mkdir -p "$TEMP_DIR" && cd "$TEMP_DIR"
    
    case "$ARCH" in
        x86_64)
            FF_URL="https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz"
            ;;
        aarch64)
            FF_URL="https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linuxarm64-gpl-7.1.tar.xz"
            ;;
        *)
            error_exit "Unsupported architecture: $ARCH"
            ;;
    esac
    
    wget -q --show-progress -O ffmpeg.tar.xz "$FF_URL" || error_exit "Failed to download FFmpeg"
    
    # Extract using tar directly (more reliable than 7z for .tar.xz)
    tar -xf ffmpeg.tar.xz
    local FF_DIR=$(tar -tf ffmpeg.tar.xz | head -1 | cut -d'/' -f1)
    
    mv "${FF_DIR}/bin/ffmpeg"  /usr/bin/xtra
    mv "${FF_DIR}/bin/ffprobe" /usr/bin/ffprobe
    mv "${FF_DIR}/bin/ffplay"  /usr/bin/ffplay
    
    chmod +x /usr/bin/xtra /usr/bin/ffprobe /usr/bin/ffplay
    rm -rf "$TEMP_DIR"
    log "✅ FFmpeg installed as 'xtra'"
}

# ── rclone → xone | aria2c → xria ──
install_rclone() {
    log "☁️ Installing rclone (xone) and aria2 (xria)..."
    
    # Install rclone properly (avoid curl|bash)
    curl -O https://downloads.rclone.org/rclone-current-linux-amd64.zip 2>/dev/null || \
    curl -O https://downloads.rclone.org/rclone-current-linux-arm64.zip 2>/dev/null
    
    unzip -q rclone-*.zip
    cd rclone-*-linux-*
    cp rclone /usr/bin/xone
    chmod 755 /usr/bin/xone
    cd ..
    rm -rf rclone-*.zip rclone-*-linux-*
    
    # Rename aria2c if exists
    if command -v aria2c &> /dev/null; then
        mv /usr/bin/aria2c /usr/bin/xria 2>/dev/null || true
    fi
    
    log "✅ rclone installed as 'xone', aria2c as 'xria'"
}

# ── MEGA SDK v4.8.0 ──
build_mega_sdk() {
    log "🔐 Building MEGA SDK v4.8.0 with Python bindings..."
    
    # Clone SDK
    git clone https://github.com/meganz/sdk.git --depth=1 -b v4.8.0 "$SDK_PATH" 2>/dev/null || \
        error_exit "Failed to clone MEGA SDK"
    
    cd "$SDK_PATH"
    rm -rf .git
    
    # ✅ Fix: autoreconf instead of autoupdate
    log "🔧 Running autoreconf..."
    autoreconf -fiv 2>/dev/null || true
    ./autogen.sh || error_exit "autogen.sh failed"
    
    # Configure and build
    log "⚙️ Configuring MEGA SDK..."
    ./configure --disable-silent-rules --enable-python --with-sodium --disable-examples || \
        error_exit "configure failed"
    
    log "🔨 Compiling MEGA SDK (this may take a while)..."
    make -j$(nproc --all) || error_exit "make failed"
    
    # ✅ Fix: Create and use virtual environment
    log "🐍 Setting up Python virtual environment..."
    python3.12 -m venv "$MEGA_VENV" || error_exit "Failed to create venv"
    source "$MEGA_VENV/bin/activate"
    
    # Build and install Python wheel
    cd bindings/python/
    python3.12 setup.py bdist_wheel || error_exit "Failed to build Python wheel"
    
    pip install --no-cache-dir dist/megasdk-4.8.0-*.whl || \
        error_exit "Failed to install MEGA SDK Python bindings"
    
    deactivate
    cd /
    
    log "✅ MEGA SDK built and Python bindings installed"
}

# ── Cleanup ──
cleanup() {
    log "🧹 Cleaning up build dependencies..."
    
    # Remove build tools (keep runtime libs)
    apt-get remove -y -qq \
        autoconf automake build-essential cmake \
        g++ gcc gettext gpg-agent intltool libtool \
        make unzip zip dh-autoreconf \
        libcurl4-openssl-dev libssl-dev libc-ares-dev \
        libsqlite3-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev \
        libffi-dev libpcre3-dev libuv1-dev 2>/dev/null || true
    
    apt-get autoremove -y -qq
    apt-get autoclean -y -qq
    
    # Remove temp directories
    rm -rf "$SDK_PATH" "$TEMP_DIR" "$MEGA_VENV"
    
    log "✅ Cleanup complete"
}

# ── Final Verification ──
verify_installation() {
    log "🔍 Verifying installations..."
    
    local errors=0
    
    # Check binaries
    for cmd in xnox xtra xone xria ffprobe ffplay python3.12; do
        if command -v "$cmd" &> /dev/null; then
            log "✅ $cmd: $(command -v $cmd)"
        else
            log "❌ $cmd: NOT FOUND"
            ((errors++))
        fi
    done
    
    # Check MEGA Python binding
    if python3.12 -c "import mega" 2>/dev/null; then
        log "✅ MEGA Python binding: OK"
    else
        log "❌ MEGA Python binding: FAILED"
        ((errors++))
    fi
    
    if [ $errors -gt 0 ]; then
        log "⚠️  $errors verification(s) failed. Check $LOG_FILE for details."
        return 1
    fi
    
    log "🎉 All installations verified successfully!"
    return 0
}

# ── Main ──
main() {
    check_root
    log "🚀 Starting setup script: $SCRIPT_NAME"
    log "📝 Log file: $LOG_FILE"
    log "🖥️  Architecture: $(uname -m)"
    log "🐧 OS: $(cat /etc/os-release | grep PRETTY_NAME | cut -d'=' -f2 | tr -d '"')"
    
    update_system
    install_python
    install_dependencies
    install_qbittorrent
    install_ffmpeg
    install_rclone
    build_mega_sdk
    cleanup
    verify_installation
    
    log "✨ Setup completed successfully!"
}

# Run main function
main "$@"
