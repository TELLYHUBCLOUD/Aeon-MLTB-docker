#!/bin/bash
# Aeon

set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

TEMP_DIR=$(mktemp -d)
JDOWNLOADER_HOME="/JDownloader"
BIN_DIR="/usr/local/bin"

download_files() {
    mkdir -p "$JDOWNLOADER_HOME" "$BIN_DIR"

    local arch
    arch=$(uname -m)

    if [ "$arch" = "x86_64" ]; then
        wget -qO "$BIN_DIR/xnox" \
            "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/x86_64-qbittorrent-nox" &

        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" \
            "https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz" &

        wget -qO "$TEMP_DIR/uv.tar.gz" \
            "https://github.com/astral-sh/uv/releases/latest/download/uv-x86_64-unknown-linux-gnu.tar.gz" &
    else
        wget -qO "$BIN_DIR/xnox" \
            "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/aarch64-qbittorrent-nox" &

        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" \
            "https://github.com/5hojib/FFmpeg-Builds/releases/latest/download/ffmpeg-n7.1-latest-linuxarm64-gpl-7.1.tar.xz" &

        wget -qO "$TEMP_DIR/uv.tar.gz" \
            "https://github.com/astral-sh/uv/releases/latest/download/uv-aarch64-unknown-linux-gnu.tar.gz" &
    fi

    wget -qO "$JDOWNLOADER_HOME/JDownloader.jar" \
        "http://installer.jdownloader.org/JDownloader.jar" &

    wait
}

install_packages() {
    apt-get update
    apt-get upgrade -y

    apt-get install -y --no-install-recommends \
        python3 \
        python3-dev \
        python3-pip \
        python3-setuptools \
        python3-wheel \
        aria2 \
        curl \
        zstd \
        xz-utils \
        git \
        libmagic-dev \
        p7zip-full \
        p7zip-rar \
        tzdata \
        wget \
        openjdk-21-jre \
        openjdk-21-jre-headless \
        build-essential \
        gcc \
        g++ \
        make \
        autoconf \
        automake \
        libtool \
        m4 \
        pkg-config \
        swig \
        cmake \
        libsodium-dev \
        libc-ares-dev \
        libssl-dev \
        libcrypto++-dev \
        libsqlite3-dev \
        libcurl4-openssl-dev \
        libfreeimage-dev \
        ca-certificates

    ln -sf /usr/bin/python3 /usr/bin/python
}

install_mega_sdk() {
    export MEGA_SDK_VERSION=4.8.0
    export PYTHONWARNINGS=ignore

    echo -e "\e[32m[INFO]: Building and Installing MegaSdkC++.\e[0m"

    git clone --depth 1 \
        --branch "v${MEGA_SDK_VERSION}" \
        https://github.com/meganz/sdk.git \
        "$TEMP_DIR/sdk"

    cd "$TEMP_DIR/sdk"

    ./autogen.sh

    ./configure \
        CFLAGS='-fpermissive' \
        CXXFLAGS='-fpermissive' \
        CPPFLAGS='-fpermissive' \
        CCFLAGS='-fpermissive' \
        --disable-silent-rules \
        --enable-python \
        --with-sodium \
        --disable-examples \
        --with-python3

    make -j"$(nproc)"

    cd bindings/python

    python3 setup.py bdist_wheel

    pip3 install dist/*.whl
}

process_files() {
    chmod +x "$BIN_DIR/xnox"

    # qBittorrent Fix
    ln -sf "$BIN_DIR/xnox" /usr/bin/qbittorrent-nox

    # FFmpeg
    tar -xf "$TEMP_DIR/ffmpeg.tar.xz" -C "$TEMP_DIR"

    local ffmpeg_dir
    ffmpeg_dir=$(find "$TEMP_DIR" -type d -name "ffmpeg-n7.1-latest-linux*" | head -n 1)

    mv "$ffmpeg_dir/bin/ffmpeg" /usr/bin/xtra
    mv "$ffmpeg_dir/bin/ffprobe" /usr/bin/ffprobe
    mv "$ffmpeg_dir/bin/ffplay" /usr/bin/ffplay

    chmod +x /usr/bin/xtra /usr/bin/ffprobe /usr/bin/ffplay

    # ffmpeg alias
    ln -sf /usr/bin/xtra /usr/bin/ffmpeg

    # UV
    tar -xzf "$TEMP_DIR/uv.tar.gz" -C "$TEMP_DIR"

    mv "$(find "$TEMP_DIR" -type f -name "uv" | head -n 1)" /usr/bin/uv

    chmod +x /usr/bin/uv

    # rclone
    curl https://rclone.org/install.sh | bash

    chmod +x /usr/bin/rclone
    chmod +x /usr/bin/aria2c

    # aliases
    ln -sf /usr/bin/rclone /usr/bin/xone
    ln -sf /usr/bin/aria2c /usr/bin/xria

    # REQUIRED FOR BOT
    ln -sf /usr/bin/aria2c /usr/bin/speeddemon

    # aria2 daemon launcher
    cat >/usr/local/bin/start-aria2 <<'EOF'
#!/bin/bash

aria2c \
  --enable-rpc \
  --rpc-listen-all=true \
  --rpc-allow-origin-all \
  --rpc-listen-port=6800 \
  --daemon=true \
  --continue=true \
  --max-connection-per-server=16 \
  --min-split-size=1M
EOF

    chmod +x /usr/local/bin/start-aria2
}

cleanup() {
    apt-get purge -y \
        perl \
        xz-utils \
        perl-modules-* \
        build-essential \
        gcc \
        g++ \
        make \
        autoconf \
        automake \
        libtool \
        m4 \
        pkg-config \
        swig \
        cmake

    apt-get install -y --no-install-recommends \
        git \
        curl \
        cpulimit

    apt-get autoremove -y --purge
    apt-get autoclean -y
    apt-get clean -y

    rm -rf \
        /var/lib/apt/lists/* \
        "$TEMP_DIR" \
        ~/.cache \
        /tmp/* \
        /var/tmp/*
}

main() {
    install_packages
    download_files
    install_mega_sdk
    process_files
    cleanup
}

main
