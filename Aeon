#!/bin/bash
set -e
set -o pipefail

# ── Configuration ──
readonly SCRIPT_NAME="$(basename "$0")"
readonly LOG_FILE="/var/log/setup_$(date +%Y%m%d_%H%M%S).log"
readonly MEGA_VENV="/opt/mega-venv"
readonly SDK_PATH="/home/sdk"
readonly TEMP_DIR="/tmp/build_temp"

# ── Logging ──
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"; }
error_exit() { log "❌ ERROR: $*"; exit 1; }

# ── Docker/Container Optimizations ──
setup_docker_env() {
    export DEBIAN_FRONTEND=noninteractive
    export TERM=dumb  # Disable terminal-specific features
    # Ignore SIGPIPE for child processes (Docker build safe)
    trap '' PIPE 2>/dev/null || true
}

# ── Root Check ──
check_root() {
    if [ "$EUID" -ne 0 ]; then error_exit "Run as root"; fi
}

# ── Update system ──
update_system() {
    log "🔄 Updating system..."
    apt-get update -qq && apt-get upgrade -y -qq
    log "✅ System updated"
}

# ── Python 3.12 ──
install_python() {
    log "🐍 Installing Python 3.12..."
    apt-get install -y -qq software-properties-common
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update -qq
    apt-get install -y -qq \
        python3.12 python3.12-dev python3.12-venv \
        python3-pip libpython3.12-dev dh-autoreconf
    log "✅ Python 3.12 installed"
}

# ── Dependencies ──
install_dependencies() {
    log "📦 Installing dependencies..."
    apt-get install -y --no-install-recommends -qq \
        apt-utils aria2 curl zstd git libmagic-dev \
        locales mediainfo neofetch p7zip-full \
        p7zip-rar tzdata wget autoconf automake \
        build-essential cmake g++ gcc gettext \
        gpg-agent intltool libtool make unzip zip \
        libcurl4-openssl-dev libsodium-dev libssl-dev \
        libcrypto++-dev libc-ares-dev libsqlite3-dev \
        libfreeimage-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev \
        pkg-config libffi-dev libpcre3-dev \
        libuv1-dev libmediainfo0v5 ca-certificates \
        libarchive-tools
    log "✅ Dependencies installed"
}

# ── qbittorrent-nox → xnox ──
install_qbittorrent() {
    log "🧲 Installing qbittorrent-nox (xnox)..."
    local ARCH=$(uname -m)
    local URL=""
    
    case "$ARCH" in
        x86_64) URL="https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/x86_64-qbittorrent-nox" ;;
        aarch64) URL="https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/aarch64-qbittorrent-nox" ;;
        *) error_exit "Unsupported arch: $ARCH" ;;
    esac
    
    mkdir -p /usr/local/bin
    # ✅ Docker-safe: disable progress bar, ignore SIGPIPE on write
    wget -q --no-verbose -O /usr/bin/xnox "$URL" || error_exit "qbittorrent download failed"
    chmod 755 /usr/bin/xnox
    log "✅ xnox installed"
}

# ── FFmpeg → xtra ──
install_ffmpeg() {
    log "🎬 Installing FFmpeg (xtra)..."
    mkdir -p "$TEMP_DIR" && cd "$TEMP_DIR"
    
    local ARCH=$(uname -m)
    local URL=""
    
    case "$ARCH" in
        x86_64) URL="https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz" ;;
        aarch64) URL="https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linuxarm64-gpl-7.1.tar.xz" ;;
        *) error_exit "Unsupported arch: $ARCH" ;;
    esac
    
    # ✅ Docker-safe download: no progress bar, retry on network issues
    wget -q --no-verbose --tries=3 -O ffmpeg.tar.xz "$URL" || error_exit "FFmpeg download failed"
    
    # ✅ Extract safely: use tar directly, avoid pipes that cause SIGPIPE
    tar -xf ffmpeg.tar.xz || error_exit "FFmpeg extraction failed"
    
    local FF_DIR
    FF_DIR=$(find . -maxdepth 1 -type d -name "ffmpeg-n7.1*" | head -1)
    [ -z "$FF_DIR" ] && error_exit "FFmpeg directory not found"
    
    mv "${FF_DIR}/bin/ffmpeg" /usr/bin/xtra
    mv "${FF_DIR}/bin/ffprobe" /usr/bin/ffprobe
    mv "${FF_DIR}/bin/ffplay" /usr/bin/ffplay
    
    chmod +x /usr/bin/xtra /usr/bin/ffprobe /usr/bin/ffplay
    cd / && rm -rf "$TEMP_DIR"
    log "✅ xtra installed"
}

# ── rclone → xone | aria2c → xria ──
install_rclone() {
    log "☁️ Installing rclone (xone) & aria2 (xria)..."
    local ARCH=$(uname -m)
    local RCLONE_ARCH=""
    
    case "$ARCH" in
        x86_64) RCLONE_ARCH="amd64" ;;
        aarch64) RCLONE_ARCH="arm64" ;;
        *) error_exit "Unsupported arch: $ARCH" ;;
    esac
    
    # ✅ Direct download with retry, no pipe to bash
    curl -fsSL --retry 3 --retry-delay 2 \
        "https://downloads.rclone.org/rclone-current-linux-${RCLONE_ARCH}.zip" \
        -o /tmp/rclone.zip || error_exit "rclone download failed"
    
    [ ! -s /tmp/rclone.zip ] && error_exit "rclone zip is empty"
    
    unzip -q -o /tmp/rclone.zip -d /tmp/ || error_exit "rclone extraction failed"
    
    local RCLONE_DIR
    RCLONE_DIR=$(find /tmp -maxdepth 1 -type d -name "rclone-*-linux-${RCLONE_ARCH}" | head -1)
    [ -z "$RCLONE_DIR" ] && error_exit "rclone directory not found"
    
    cp "${RCLONE_DIR}/rclone" /usr/bin/xone
    chmod 755 /usr/bin/xone
    
    rm -rf /tmp/rclone.zip /tmp/rclone-*-linux-*
    
    # Rename aria2c if exists
    [ -f /usr/bin/aria2c ] && mv /usr/bin/aria2c /usr/bin/xria
    log "✅ xone & xria installed"
}

# ── MEGA SDK v4.8.0 ──
build_mega_sdk() {
    log "🔐 Building MEGA SDK v4.8.0..."
    
    git clone https://github.com/meganz/sdk.git --depth=1 -b v4.8.0 "$SDK_PATH" 2>/dev/null || \
        error_exit "SDK clone failed"
    
    cd "$SDK_PATH"
    rm -rf .git
    
    # ✅ autoreconf with SIGPIPE tolerance
    autoreconf -fiv 2>/dev/null || true
    ./autogen.sh || error_exit "autogen.sh failed"
    
    ./configure --disable-silent-rules --enable-python --with-sodium --disable-examples || \
        error_exit "configure failed"
    
    log "🔨 Compiling MEGA SDK (this may take 15-30 min)..."
    make -j$(nproc --all) || error_exit "make failed"
    
    # ✅ Python venv setup
    python3.12 -m venv "$MEGA_VENV" || error_exit "venv creation failed"
    source "$MEGA_VENV/bin/activate"
    
    cd bindings/python/
    python3.12 setup.py bdist_wheel || error_exit "wheel build failed"
    
    pip install --no-cache-dir dist/megasdk-4.8.0-*.whl || \
        error_exit "pip install failed"
    
    deactivate
    cd /
    log "✅ MEGA SDK built & Python bindings installed"
}

# ── Cleanup ──
cleanup() {
    log "🧹 Cleaning up build dependencies..."
    
    apt-get remove -y -qq \
        autoconf automake build-essential cmake \
        g++ gcc gettext gpg-agent intltool libtool \
        make unzip zip dh-autoreconf \
        libcurl4-openssl-dev libssl-dev libc-ares-dev \
        libsqlite3-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev \
        libffi-dev libpcre3-dev libuv1-dev 2>/dev/null || true
    
    apt-get autoremove -y -qq
    apt-get autoclean -y -qq
    
    rm -rf "$SDK_PATH" "$TEMP_DIR" "$MEGA_VENV"
    log "✅ Cleanup complete"
}

# ── Main ──
main() {
    check_root
    setup_docker_env
    log "🚀 Starting Aeon setup in Docker"
    log "🖥️  Arch: $(uname -m) | OS: $(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)"
    
    update_system
    install_python
    install_dependencies
    install_qbittorrent
    install_ffmpeg
    install_rclone
    build_mega_sdk
    cleanup
    
    log "✨ Aeon setup completed successfully!"
}

main "$@"
