#!/bin/bash
# Aeon - Optimized & Robust Docker Build Script
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
TEMP_DIR=$(mktemp -d)
JDOWNLOADER_HOME="/JDownloader"
BIN_DIR="/usr/local/bin"

download_files() {
    echo "Downloading system binaries..."
    mkdir -p "$JDOWNLOADER_HOME" "$BIN_DIR"
    local arch=$(uname -m)
    local pids=()

    if [ "$arch" = "x86_64" ]; then
        wget -qO "$BIN_DIR/xnox" "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/x86_64-qbittorrent-nox" &
        pids+=($!)
        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" "https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz" &
        pids+=($!)
        wget -qO "$TEMP_DIR/uv.tar.gz" "https://github.com/astral-sh/uv/releases/latest/download/uv-x86_64-unknown-linux-gnu.tar.gz" &
        pids+=($!)
    else
        wget -qO "$BIN_DIR/xnox" "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/aarch64-qbittorrent-nox" &
        pids+=($!)
        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" "https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linuxarm64-gpl-7.1.tar.xz" &
        pids+=($!)
        wget -qO "$TEMP_DIR/uv.tar.gz" "https://github.com/astral-sh/uv/releases/latest/download/uv-aarch64-unknown-linux-gnu.tar.gz" &
        pids+=($!)
    fi

    wget -qO "$JDOWNLOADER_HOME/JDownloader.jar" "http://installer.jdownloader.org/JDownloader.jar" &
    pids+=($!)

    # Wait for all background downloads individually to catch failures
    for pid in "${pids[@]}"; do
        if ! wait "$pid"; then
            echo "ERROR: Download failed for PID $pid" >&2
            exit 1
        fi
    done
}

install_packages() {
    echo "Installing system packages and build dependencies..."
    apt-get update
    apt-get install -y --no-install-recommends \
        python3-pip \
        python3-setuptools \
        python3-dev \
        aria2 \
        curl \
        zstd \
        xz-utils \
        git \
        unzip \
        libmagic1 \
        libmagic-dev \
        libglib2.0-0 \
        p7zip-full \
        p7zip-rar \
        tzdata \
        wget \
        openjdk-21-jre-headless \
        autoconf \
        automake \
        build-essential \
        cmake \
        g++ \
        gcc \
        gettext \
        intltool \
        libtool \
        make \
        swig \
        libcurl4-openssl-dev \
        libsodium-dev \
        libssl-dev \
        libcrypto++-dev \
        libc-ares-dev \
        libsqlite3-dev \
        libfreeimage-dev \
        libboost-all-dev \
        libpthread-stubs0-dev \
        zlib1g-dev

    # Ensure dynamic links for python commands
    if ! command -v python &>/dev/null; then
        ln -sf "$(which python3)" /usr/bin/python
    fi
}

process_files() {
    echo "Extracting and placing binaries..."
    chmod 755 "$BIN_DIR/xnox"

    # Extract FFmpeg
    tar -xf "$TEMP_DIR/ffmpeg.tar.xz" -C "$TEMP_DIR"
    local ffmpeg_dir=$(find "$TEMP_DIR" -type d -name "ffmpeg-n7.1-latest-linux*" | head -n 1)
    if [ -z "$ffmpeg_dir" ]; then
        echo "ERROR: FFmpeg directory not found after extraction" >&2
        exit 1
    fi
    mv "$ffmpeg_dir/bin/ffmpeg" /usr/bin/xtra
    mv "$ffmpeg_dir/bin/ffprobe" /usr/bin/ffprobe
    mv "$ffmpeg_dir/bin/ffplay" /usr/bin/ffplay
    chmod +x /usr/bin/xtra /usr/bin/ffprobe /usr/bin/ffplay

    # Extract UV
    tar -xzf "$TEMP_DIR/uv.tar.gz" -C "$TEMP_DIR"
    local uv_bin=$(find "$TEMP_DIR" -type f -name "uv" | head -n 1)
    if [ -z "$uv_bin" ]; then
        echo "ERROR: UV binary not found after extraction" >&2
        exit 1
    fi
    mv "$uv_bin" /usr/bin/uv
    chmod +x /usr/bin/uv

    # Install rclone safely
    curl -o /tmp/rclone-install.sh https://rclone.org/install.sh
    bash /tmp/rclone-install.sh
    rm -f /tmp/rclone-install.sh

    # Symlinks for apt-managed binaries (aria2c, rclone)
    ln -sf /usr/bin/aria2c /usr/bin/xria
    ln -sf /usr/bin/aria2c /usr/bin/speeddemon
    
    ln -sf /usr/bin/rclone /usr/bin/xone
    ln -sf /usr/bin/rclone /usr/bin/cloudphantom

    # Symlinks for manually placed binaries (matching bot's BinConfig)
    ln -sf /usr/local/bin/xnox /usr/local/bin/qbittorrent-nox
    ln -sf /usr/local/bin/xnox /usr/local/bin/torrentgod
    ln -sf /usr/bin/xtra /usr/bin/ffmpeg
    ln -sf /usr/bin/xtra /usr/bin/vidwarlock
}

build_mega_sdk() {
    echo "Building Mega SDK and Python bindings..."
    # Ensure setuptools and wheel are installed in system Python
    uv pip install --system --no-cache-dir setuptools wheel

    git clone https://github.com/meganz/sdk.git --depth=1 -b v4.8.0 /home/sdk
    cd /home/sdk
    rm -rf .git
    
    ./autogen.sh
    ./configure --disable-silent-rules --enable-python --with-sodium --disable-examples
    
    # Cap CPU cores to 4 during build to prevent Out-Of-Memory compilation crashes
    local cores=$(nproc)
    if [ "$cores" -gt 4 ]; then
        cores=4
    fi
    echo "Compiling on $cores cores..."
    make -j"$cores"
    make install
    ldconfig

    cd bindings/python/
    python3 setup.py bdist_wheel
    uv pip install --system --no-cache-dir dist/megasdk-*.whl

    rm -rf /home/sdk
}

install_python_requirements() {
    if [ -f /tmp/requirements.txt ]; then
        echo "Installing Python requirements with uv..."
        uv pip install --system --no-cache-dir -r /tmp/requirements.txt
        rm /tmp/requirements.txt
    else
        echo "WARNING: /tmp/requirements.txt not found, skipping Python package installation" >&2
    fi
}

cleanup() {
    echo "Cleaning up build dependencies..."
    # Purge only compilers and code generation build tools
    # Crucially do NOT purge the dev libraries (e.g. libc-ares-dev) so their runtime counterparts are safe from autoremove
    apt-get purge -y \
        autoconf \
        automake \
        build-essential \
        cmake \
        g++ \
        gcc \
        gettext \
        intltool \
        libtool \
        make \
        swig

    # Install cpulimit for runtime CPU throttling
    apt-get install -y --no-install-recommends cpulimit

    # Clean up apt caches
    apt-get autoremove -y --purge
    apt-get autoclean -y
    apt-get clean -y

    # Clear temporary build dirs
    rm -rf \
        /var/lib/apt/lists/* \
        "$TEMP_DIR" \
        Aeon \
        Dockerfile \
        ~/.cache \
        /tmp/* \
        /var/tmp/*
}

main() {
    install_packages
    download_files
    process_files
    build_mega_sdk
    install_python_requirements
    cleanup
    echo "Installation finished successfully!"
}

main
