#!/bin/bash
# Aeon
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
TEMP_DIR=$(mktemp -d)
JDOWNLOADER_HOME="/JDownloader"
BIN_DIR="/usr/local/bin"

download_files() {
    mkdir -p "$JDOWNLOADER_HOME" "$BIN_DIR"
    local arch=$(uname -m)

    if [ "$arch" = "x86_64" ]; then
        wget -qO "$BIN_DIR/xnox" "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/x86_64-qbittorrent-nox" &
        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" "https://github.com/5hojib/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz" &
        wget -qO "$TEMP_DIR/uv.tar.gz" "https://github.com/astral-sh/uv/releases/latest/download/uv-x86_64-unknown-linux-gnu.tar.gz" &
    else
        wget -qO "$BIN_DIR/xnox" "https://github.com/userdocs/qbittorrent-nox-static/releases/latest/download/aarch64-qbittorrent-nox" &
        wget -qO "$TEMP_DIR/ffmpeg.tar.xz" "https://github.com/5hojib/FFmpeg-Builds/releases/latest/download/ffmpeg-n7.1-latest-linuxarm64-gpl-7.1.tar.xz" &
        wget -qO "$TEMP_DIR/uv.tar.gz" "https://github.com/astral-sh/uv/releases/latest/download/uv-aarch64-unknown-linux-gnu.tar.gz" &
    fi

    wget -qO "$JDOWNLOADER_HOME/JDownloader.jar" http://installer.jdownloader.org/JDownloader.jar &

    wait
}

install_packages() {
    apt-get update
    apt-get upgrade -y

    apt-get install -y --no-install-recommends \
        python3-pip \
        python3.12 \
        python3-setuptools \
        libpython3.12 \
        libpython3.12-dev \
        python3.12-dev \
        libmediainfo-dev \
        libzen-dev \
        aria2 \
        curl \
        zstd \
        xz-utils \
        git \
        libmagic-dev \
        p7zip-full \
        p7zip-rar \
        tzdata \
        wget \
        openjdk-21-jre \
        openjdk-21-jre-headless \
        autoconf \
        automake \
        build-essential \
        cmake \
        g++ \
        gcc \
        gettext \
        intltool \
        libtool \
        make \
        swig \
        libcurl4-gnutls-dev \
        libsodium-dev \
        libssl-dev \
        libcrypto++-dev \
        libc-ares-dev \
        libsqlite3-dev \
        libfreeimage-dev \
        libboost-all-dev \
        libpthread-stubs0-dev \
        zlib1g-dev \
        ca-certificates

    ln -sf /usr/bin/python3.12 /usr/bin/python3
    ln -sf /usr/bin/python3.12 /usr/bin/python
}

process_files() {
    chmod 700 "$BIN_DIR/xnox"

    # Extract FFmpeg
    tar -xf "$TEMP_DIR/ffmpeg.tar.xz" -C "$TEMP_DIR"
    local ffmpeg_dir=$(find "$TEMP_DIR" -type d -name "ffmpeg-n7.1-latest-linux*" | head -n 1)
    mv "$ffmpeg_dir/bin/ffmpeg" /usr/bin/xtra
    mv "$ffmpeg_dir/bin/ffprobe" /usr/bin/ffprobe
    mv "$ffmpeg_dir/bin/ffplay" /usr/bin/ffplay
    chmod +x /usr/bin/xtra /usr/bin/ffprobe /usr/bin/ffplay

    # Extract UV
    tar -xzf "$TEMP_DIR/uv.tar.gz" -C "$TEMP_DIR"
    mv "$(find "$TEMP_DIR" -type f -name "uv" | head -n 1)" /usr/bin/uv
    chmod +x /usr/bin/uv

    # Install rclone
    curl https://rclone.org/install.sh | bash
    mv /usr/bin/rclone /usr/bin/xone
    mv /usr/bin/aria2c /usr/bin/xria

    # Symlinks — app ke saare expected binary names
    ln -sf /usr/local/bin/xnox /usr/local/bin/qbittorrent-nox
    ln -sf /usr/local/bin/xnox /usr/local/bin/torrentgod
    ln -sf /usr/bin/xria /usr/bin/aria2c
    ln -sf /usr/bin/xria /usr/bin/speeddemon
    ln -sf /usr/bin/xtra /usr/bin/ffmpeg
    ln -sf /usr/bin/xtra /usr/bin/vidwarlock
    ln -sf /usr/bin/xone /usr/bin/rclone
    ln -sf /usr/bin/xone /usr/bin/cloudphantom
}

build_mega_sdk() {
    python3 -m pip install --break-system-packages setuptools

    git clone https://github.com/meganz/sdk.git --depth=1 -b v8.0.0 /home/sdk
    cd /home/sdk
    rm -rf .git

    mkdir -p build && cd build
    cmake .. \
        -DENABLE_PYTHON_BINDINGS=ON \
        -DUSE_SODIUM=ON \
        -DENABLE_EXAMPLES=OFF \
        -DCMAKE_BUILD_TYPE=Release
    make -j$(nproc --all)
    make install
    ldconfig

    cd ../bindings/python/
    python3.13 setup.py bdist_wheel
    python3 -m pip install --break-system-packages --no-cache-dir dist/megasdk-*.whl

    rm -rf /home/sdk
}

cleanup() {
    apt-get purge -y \
        wget \
        perl \
        xz-utils \
        perl-modules-5.40 \
        autoconf \
        automake \
        build-essential \
        cmake \
        g++ \
        gcc \
        gettext \
        intltool \
        libtool \
        make \
        swig \
        libcurl4-openssl-dev \
        libc-ares-dev \
        libsqlite3-dev \
        libboost-all-dev \
        libpthread-stubs0-dev \
        zlib1g-dev
        # libssl-dev NAHI hatana — runtime mein chahiye

    apt-get install -y --no-install-recommends \
        git \
        curl \
        cpulimit

    apt-get autoremove -y --purge
    apt-get autoclean -y
    apt-get clean -y

    rm -rf \
        /var/lib/apt/lists/* \
        "$TEMP_DIR" \
        Aeon \
        Dockerfile \
        ~/.cache \
        /tmp/* \
        /var/tmp/*
}

main() {
    install_packages
    download_files
    process_files
    build_mega_sdk
    cleanup
}

main
