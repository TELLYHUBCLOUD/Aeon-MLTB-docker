#!/bin/bash

# Set environment variables
export DEBIAN_FRONTEND=noninteractive
export PYTHONUNBUFFERED=1
export PYTHONDONTWRITEBYTECODE=1
export PIP_BREAK_SYSTEM_PACKAGES=1
export LD_LIBRARY_PATH="/usr/local/lib:${LD_LIBRARY_PATH}"
export PATH="/root/.cargo/bin:/root/.local/bin:/usr/local/bin:${PATH}"

# Update and upgrade system packages
update_system() {
    echo "======================================"
    echo "📦 Updating system packages..."
    echo "======================================"
    apt-get update && apt-get upgrade -y
}

# Install Python 3.13 and essential dependencies
install_python() {
    echo "======================================"
    echo "🐍 Installing Python 3.13..."
    echo "======================================"
    apt-get install -y software-properties-common
    add-apt-repository -y ppa:deadsnakes/ppa
    apt-get update
    apt-get install -y python3.13 python3.13-dev python3.13-venv python3-pip \
        libpython3.13 libpython3.13-dev python3.13-distutils
    
    # Set Python 3.13 as default
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.13 1
    update-alternatives --set python3 /usr/bin/python3.13
    
    # Install pip and setuptools properly
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3
    python3 -m pip install --force-reinstall --break-system-packages pip setuptools wheel
    
    # Verify installation
    python3 --version
    pip3 --version
    echo "✅ Python 3.13 installed successfully"
}

# Install all system dependencies
install_dependencies() {
    echo "======================================"
    echo "📚 Installing system dependencies..."
    echo "======================================"
    apt-get install -y --no-install-recommends \
        apt-utils aria2 curl zstd git libmagic-dev libmagic1 \
        locales mediainfo libmediainfo0v5 neofetch p7zip-full \
        p7zip-rar tzdata wget autoconf automake \
        build-essential cmake g++ gcc gettext \
        gpg-agent intltool libtool make unzip zip tar xz-utils \
        libcurl4-openssl-dev libsodium-dev libssl-dev \
        libcrypto++-dev libc-ares-dev libsqlite3-dev \
        libfreeimage-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev libffi-dev \
        libpcre3-dev libuv1-dev pkg-config \
        ca-certificates openjdk-17-jre-headless \
        cpulimit util-linux procps
    
    echo "✅ System dependencies installed"
}

# Download and install qbittorrent-nox
install_qbittorrent() {
    echo "======================================"
    echo "🌊 Installing qBittorrent-nox..."
    echo "======================================"
    ARCH=$(uname -m)
    mkdir -p /usr/local/bin

    case "$ARCH" in
        x86_64)
            wget -qO /usr/local/bin/xnox https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/x86_64-qbittorrent-nox
            ;;
        aarch64)
            wget -qO /usr/local/bin/xnox https://github.com/userdocs/qbittorrent-nox-static/releases/download/release-4.6.7_v2.0.10/aarch64-qbittorrent-nox
            ;;
        *)
            echo "❌ Unsupported architecture: $ARCH"
            exit 1
            ;;
    esac

    chmod 700 /usr/local/bin/xnox
    ln -sf /usr/local/bin/xnox /usr/local/bin/torrentgod
    echo "✅ qBittorrent-nox installed"
}

# Install FFmpeg from BtbN (Latest build)
install_ffmpeg() {
    echo "======================================"
    echo "🎬 Installing FFmpeg (BtbN Latest)..."
    echo "======================================"
    ARCH=$(uname -m)
    mkdir -p /Temp
    cd /Temp

    case "$ARCH" in
        x86_64)
            echo "📥 Downloading FFmpeg for x86_64..."
            FFMPEG_URL="https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz"
            wget -q --show-progress -O ffmpeg.tar.xz "$FFMPEG_URL"
            ;;
        aarch64)
            echo "📥 Downloading FFmpeg for aarch64..."
            FFMPEG_URL="https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linuxarm64-gpl.tar.xz"
            wget -q --show-progress -O ffmpeg.tar.xz "$FFMPEG_URL"
            ;;
        *)
            echo "❌ Unsupported architecture: $ARCH"
            exit 1
            ;;
    esac

    echo "📦 Extracting FFmpeg..."
    tar -xf ffmpeg.tar.xz
    
    # Find the extracted directory
    FFMPEG_DIR=$(find /Temp -maxdepth 1 -type d -name "ffmpeg-*" | head -n 1)
    
    if [ -z "$FFMPEG_DIR" ]; then
        echo "❌ FFmpeg extraction failed"
        ls -la /Temp
        exit 1
    fi
    
    echo "Found FFmpeg directory: $FFMPEG_DIR"
    
    # Move binaries
    if [ -f "$FFMPEG_DIR/bin/ffmpeg" ]; then
        mv "$FFMPEG_DIR/bin/ffmpeg" /usr/bin/xtra
        chmod +x /usr/bin/xtra
    else
        echo "❌ ffmpeg binary not found"
        exit 1
    fi
    
    if [ -f "$FFMPEG_DIR/bin/ffprobe" ]; then
        mv "$FFMPEG_DIR/bin/ffprobe" /usr/bin/ffprobe
        chmod +x /usr/bin/ffprobe
    fi
    
    # ffplay might not exist in all builds
    if [ -f "$FFMPEG_DIR/bin/ffplay" ]; then
        mv "$FFMPEG_DIR/bin/ffplay" /usr/bin/ffplay
        chmod +x /usr/bin/ffplay
    fi
    
    # Create symlinks
    ln -sf /usr/bin/xtra /usr/local/bin/vidwarlock
    ln -sf /usr/bin/xtra /usr/local/bin/ffmpeg
    ln -sf /usr/bin/ffprobe /usr/local/bin/ffprobe
    
    # Verify installation
    /usr/bin/xtra -version | head -n 1
    echo "✅ FFmpeg installed successfully"
}

# Install rclone
install_rclone() {
    echo "======================================"
    echo "☁️  Installing rclone..."
    echo "======================================"
    curl -s https://rclone.org/install.sh | bash
    
    mv /usr/bin/rclone /usr/bin/xone
    mv /usr/bin/aria2c /usr/bin/xria
    
    ln -sf /usr/bin/xone /usr/local/bin/cloudphantom
    ln -sf /usr/bin/xone /usr/local/bin/rclone
    ln -sf /usr/bin/xria /usr/local/bin/speeddemon
    ln -sf /usr/bin/xria /usr/local/bin/aria2c
    
    echo "✅ rclone & aria2c installed"
}

# Install UV
install_uv() {
    echo "======================================"
    echo "⚡ Installing UV package manager..."
    echo "======================================"
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.cargo/bin:$PATH"
    echo 'export PATH="/root/.cargo/bin:$PATH"' >> /root/.bashrc
    
    if command -v uv &> /dev/null; then
        uv --version
        echo "✅ UV installed successfully"
    else
        echo "⚠️  UV installation completed but not in PATH"
    fi
}

# Install JDownloader
install_jdownloader() {
    echo "======================================"
    echo "📥 Installing JDownloader..."
    echo "======================================"
    mkdir -p /JDownloader/cfg
    wget -q --show-progress -O /JDownloader/JDownloader.jar http://installer.jdownloader.org/JDownloader.jar
    echo "✅ JDownloader installed"
}

# Install Python packages
install_python_packages() {
    echo "======================================"
    echo "📦 Installing Python packages..."
    echo "======================================"
    
    # Ensure setuptools is working
    python3 -m pip install --break-system-packages --force-reinstall setuptools wheel
    
    if [ -f "/tmp/requirements.txt" ] || [ -f "requirements.txt" ]; then
        REQ_FILE="/tmp/requirements.txt"
        [ ! -f "$REQ_FILE" ] && REQ_FILE="requirements.txt"
        
        echo "Installing from requirements.txt..."
        pip3 install --break-system-packages --no-cache-dir -r "$REQ_FILE" || echo "⚠️  Some packages failed"
    else
        echo "Installing default packages..."
        pip3 install --break-system-packages --no-cache-dir -U \
            aiohttp aiofiles aioshutil anytree==2.8.0 apscheduler aria2p \
            beautifulsoup4 bencoding cinemagoer cloudscraper dnspython electrogram feedparser flask gevent \
            google-api-python-client google-auth-httplib2 google-auth-oauthlib \
            gunicorn httpx langcodes lxml motor mutagen markdown natsort pillow psutil \
            pybase64 pycountry python-dotenv python-magic qbittorrent-api requests \
            setuptools speedtest-cli telegraph tenacity uvloop xattr yt-dlp[default]
        
        # Try pyshorteners separately
        pip3 install --break-system-packages --no-cache-dir pyshorteners || \
        pip3 install --break-system-packages --no-cache-dir --no-build-isolation pyshorteners || \
        echo "⚠️  pyshorteners skipped"
    fi
    
    echo "✅ Python packages installed"
}

# Clone and build MEGA SDK 4.8.0
build_mega_sdk() {
    git clone https://github.com/meganz/sdk.git --depth=1 -b v4.8.0 /home/sdk
    cd /home/sdk
    rm -rf .git
    autoupdate -fIv && ./autogen.sh
    ./configure --disable-silent-rules --enable-python --with-sodium --disable-examples
    make -j$(nproc --all)

    cd bindings/python/
    python3.12 setup.py bdist_wheel
    pip3 install --break-system-packages --no-cache-dir dist/megasdk-4.8.0-*.whl
}

# Create symlinks
create_symlinks() {
    echo "======================================"
    echo "🔗 Creating symlinks..."
    echo "======================================"
    ln -sf /usr/bin/ffprobe /usr/local/bin/ffprobe
    [ -f /usr/bin/ffplay ] && ln -sf /usr/bin/ffplay /usr/local/bin/ffplay
    ln -sf /usr/bin/mediainfo /usr/local/bin/mediainfo
    echo "✅ Symlinks created"
}

# Verify installations
verify_installations() {
    echo "======================================"
    echo "✅ Verifying installations..."
    echo "======================================"
    
    echo "Python: $(python3 --version)"
    echo "Pip: $(pip3 --version)"
    
    if /usr/bin/xtra -version &> /dev/null; then
        echo "FFmpeg: $(/usr/bin/xtra -version 2>&1 | head -n 1)"
    else
        echo "FFmpeg: ❌ Not working"
    fi
    
    echo "rclone: $(xone version 2>&1 | head -n 1)"
    echo "aria2c: $(xria --version 2>&1 | head -n 1)"
    echo "qBittorrent: $(xnox --version 2>&1 | head -n 1)"
    
    export PATH="/root/.cargo/bin:$PATH"
    if command -v uv &> /dev/null; then
        echo "UV: $(uv --version)"
    else
        echo "UV: ⚠️  Not in PATH"
    fi
    
    python3 -c "import mega" 2>/dev/null && echo "MEGA SDK: ✅ OK" || echo "MEGA SDK: ⚠️  Failed"
    ffmpeg -version > /dev/null 2>&1 && echo "FFmpeg symlink: ✅ OK" || echo "FFmpeg symlink: ⚠️  Failed"
    python3 -c "from setuptools import setup" 2>/dev/null && echo "setuptools: ✅ OK" || echo "setuptools: ⚠️  Failed"
    
    echo "======================================"
}

# Cleanup
cleanup() {
    echo "======================================"
    echo "🧹 Cleaning up..."
    echo "======================================"
    
    apt-get purge -y \
        autoconf automake build-essential cmake g++ gcc gettext \
        gpg-agent intltool libtool make unzip zip libcurl4-openssl-dev \
        libssl-dev libc-ares-dev libsqlite3-dev swig libboost-all-dev \
        libpthread-stubs0-dev zlib1g-dev
    
    apt-get autoremove -y
    apt-get autoclean -y
    apt-get clean
    
    rm -rf /Temp /home/sdk /tmp/requirements.txt /var/lib/apt/lists/* Dockerfile
    
    echo "✅ Cleanup completed"
}

# Set working directory
set_workdir() {
    echo "======================================"
    echo "📁 Setting up working directory..."
    echo "======================================"
    mkdir -p /usr/src/app
    cd /usr/src/app
    chmod -R 777 /usr/src/app
    echo "✅ Working directory: /usr/src/app"
}

# Main execution
main() {
    echo "======================================"
    echo "🚀 WZML-X Installation Script"
    echo "======================================"
    echo "Started at: $(date)"
    echo ""
    
    update_system
    install_python
    install_dependencies
    install_qbittorrent
    install_ffmpeg
    install_rclone
    install_uv
    install_jdownloader
    install_python_packages
    build_mega_sdk
    create_symlinks
    verify_installations
    cleanup
    set_workdir
    
    echo ""
    echo "======================================"
    echo "✅ Installation completed!"
    echo "======================================"
    echo ""
    echo "📦 Installed components:"
    echo "   • Python 3.13 with setuptools"
    echo "   • qBittorrent-nox (xnox, torrentgod)"
    echo "   • FFmpeg latest (xtra, vidwarlock, ffmpeg)"
    echo "   • rclone (xone, cloudphantom)"
    echo "   • aria2 (xria, speeddemon)"
    echo "   • JDownloader"
    echo "   • MEGA SDK v8.1.1"
    echo "   • UV package manager"
    echo ""
    echo "📁 Working directory: /usr/src/app"
    echo "⏰ Completed at: $(date)"
    echo "======================================"
}

main
